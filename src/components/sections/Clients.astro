---
---

<section class="clients-section py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-dark">Our Clients</h2>
      <p class="text-sm text-gray mt-2">We have been working with some Fortune 500+ clients</p>
    </div>

    <!-- Logo grid -->
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16">
      <!-- Logo 1: Group/People -->
      <div class="client-logo flex items-center gap-2 opacity-70 hover:opacity-100 transition-opacity">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="18" cy="16" r="7" fill="#B0BEC5"/>
          <circle cx="30" cy="16" r="7" fill="#90A4AE"/>
          <path d="M4 40c0-8 6-14 14-14s14 6 14 14" stroke="#B0BEC5" stroke-width="3" fill="none"/>
          <path d="M28 40c0-8 4-13 10-14" stroke="#90A4AE" stroke-width="3" fill="none"/>
        </svg>
        <span class="font-semibold text-gray text-sm tracking-wide uppercase hidden sm:block">TeamSync</span>
      </div>

      <!-- Logo 2: Shield -->
      <div class="client-logo opacity-70 hover:opacity-100 transition-opacity">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 6L8 12v12c0 10 7 18 16 20 9-2 16-10 16-20V12L24 6z" fill="#CFD8DC" stroke="#90A4AE" stroke-width="2"/>
          <path d="M16 24l6 6 10-10" stroke="#4CAF50" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Logo 3: Chart/Tag -->
      <div class="client-logo opacity-70 hover:opacity-100 transition-opacity">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="6" y="6" width="36" height="36" rx="8" fill="#CFD8DC"/>
          <rect x="14" y="28" width="6" height="10" rx="2" fill="#78909C"/>
          <rect x="24" y="20" width="6" height="18" rx="2" fill="#546E7A"/>
          <rect x="34" y="14" width="6" height="24" rx="2" fill="#4CAF50"/>
        </svg>
      </div>

      <!-- Logo 4: Leaf/Brand -->
      <div class="client-logo opacity-70 hover:opacity-100 transition-opacity flex items-center gap-1">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="20" cy="20" r="18" fill="#E8F5E9"/>
          <path d="M20 8 C8 12 8 28 20 32 C32 28 32 12 20 8z" fill="#4CAF50"/>
          <path d="M20 8 L20 32" stroke="white" stroke-width="1.5"/>
          <path d="M20 16 C14 16 12 22 14 26" stroke="white" stroke-width="1.5" fill="none"/>
        </svg>
      </div>

      <!-- Logo 5: Chain/Link -->
      <div class="client-logo opacity-70 hover:opacity-100 transition-opacity">
        <svg width="56" height="32" viewBox="0 0 56 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="6" width="24" height="20" rx="10" fill="none" stroke="#90A4AE" stroke-width="3"/>
          <rect x="30" y="6" width="24" height="20" rx="10" fill="none" stroke="#B0BEC5" stroke-width="3"/>
          <rect x="22" y="11" width="12" height="10" fill="white"/>
        </svg>
      </div>

      <!-- Logo 6: Lock -->
      <div class="client-logo opacity-70 hover:opacity-100 transition-opacity">
        <svg width="40" height="48" viewBox="0 0 40 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 22V14a12 12 0 0124 0v8" stroke="#90A4AE" stroke-width="3" fill="none" stroke-linecap="round"/>
          <rect x="4" y="22" width="32" height="24" rx="6" fill="#CFD8DC"/>
          <circle cx="20" cy="34" r="4" fill="#78909C"/>
          <rect x="18" y="34" width="4" height="6" rx="2" fill="#78909C"/>
        </svg>
      </div>

      <!-- Logo 7: Diamond -->
      <div class="client-logo opacity-70 hover:opacity-100 transition-opacity">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="4" width="40" height="40" rx="6" fill="#CFD8DC"/>
          <path d="M14 18h20l-10 16-10-16z" fill="#546E7A"/>
          <path d="M14 18l10 6 10-6" stroke="white" stroke-width="1.5" fill="none"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .clients-section {
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
  }
</style>
