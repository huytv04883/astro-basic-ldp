---
---

<section class="hero-section pt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 flex flex-col-reverse md:flex-row items-center gap-12">
    <!-- Text -->
    <div class="flex-1 text-center md:text-left">
      <h1 class="text-4xl md:text-5xl font-bold text-dark leading-tight mb-4">
        Lessons and insights<br />
        <span class="text-primary">from 8 years</span>
      </h1>
      <p class="text-base text-gray mb-8 max-w-md mx-auto md:mx-0">
        Where to grow your business as a photographer: site or social media?
      </p>
      <a
        href="#"
        class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-md transition-colors text-sm"
      >
        Register
      </a>
      <!-- Dots -->
      <div class="flex gap-2 justify-center md:justify-start mt-10">
        <span class="w-3 h-3 rounded-full bg-primary"></span>
        <span class="w-3 h-3 rounded-full bg-gray-dot"></span>
        <span class="w-3 h-3 rounded-full bg-gray-dot"></span>
      </div>
    </div>

    <!-- Illustration -->
    <div class="flex-1 flex justify-center md:justify-end">
      <div class="hero-illustration relative w-full max-w-lg">
        <!-- Decorative background shape -->
        <div class="absolute inset-0 hero-bg-shape rounded-full opacity-10 bg-primary transform scale-90 blur-2xl"></div>
        <svg viewBox="0 0 500 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full relative z-10">
          <!-- Monitor stand -->
          <rect x="195" y="290" width="110" height="12" rx="4" fill="#B0BEC5"/>
          <rect x="220" y="260" width="60" height="32" rx="2" fill="#B0BEC5"/>
          <!-- Monitor -->
          <rect x="80" y="60" width="340" height="210" rx="12" fill="#263238"/>
          <rect x="92" y="72" width="316" height="188" rx="8" fill="#37474F"/>
          <!-- Screen content -->
          <rect x="100" y="80" width="300" height="170" rx="6" fill="#ECEFF1"/>
          <rect x="110" y="92" width="120" height="8" rx="4" fill="#4CAF50"/>
          <rect x="110" y="108" width="200" height="5" rx="3" fill="#B0BEC5"/>
          <rect x="110" y="120" width="160" height="5" rx="3" fill="#B0BEC5"/>
          <rect x="110" y="132" width="180" height="5" rx="3" fill="#B0BEC5"/>
          <rect x="110" y="148" width="80" height="28" rx="6" fill="#4CAF50"/>
          <rect x="210" y="92" width="180" height="90" rx="8" fill="#C8E6C9"/>
          <rect x="220" y="100" width="160" height="74" rx="6" fill="#A5D6A7"/>
          <!-- Chart lines on screen -->
          <polyline points="225,165 245,145 265,155 285,135 305,140 325,125 345,130 365,115" stroke="#4CAF50" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <!-- Person figure -->
          <circle cx="380" cy="165" r="24" fill="#FFCCBC"/>
          <rect x="358" y="190" width="44" height="60" rx="6" fill="#4CAF50"/>
          <rect x="348" y="200" width="20" height="10" rx="5" fill="#FFCCBC"/>
          <rect x="392" y="200" width="20" height="10" rx="5" fill="#FFCCBC"/>
          <rect x="362" y="248" width="16" height="30" rx="5" fill="#263238"/>
          <rect x="382" y="248" width="16" height="30" rx="5" fill="#263238"/>
          <!-- Clipboard in hand -->
          <rect x="394" y="195" width="30" height="38" rx="4" fill="white" stroke="#B0BEC5" stroke-width="1.5"/>
          <rect x="399" y="202" width="20" height="3" rx="2" fill="#4CAF50"/>
          <rect x="399" y="210" width="14" height="3" rx="2" fill="#B0BEC5"/>
          <rect x="399" y="218" width="16" height="3" rx="2" fill="#B0BEC5"/>
          <!-- Gear decorations -->
          <circle cx="60" cy="290" r="22" fill="none" stroke="#E0E0E0" stroke-width="3"/>
          <circle cx="60" cy="290" r="10" fill="none" stroke="#E0E0E0" stroke-width="3"/>
          <circle cx="440" cy="300" r="16" fill="none" stroke="#E0E0E0" stroke-width="3"/>
          <circle cx="440" cy="300" r="7" fill="none" stroke="#E0E0E0" stroke-width="3"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: linear-gradient(135deg, #ffffff 0%, #f9fffe 100%);
    border-bottom: 1px solid #f0f0f0;
  }
</style>
